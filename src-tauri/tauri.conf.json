{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aria",
  "version": "0.1.0",
  "identifier": "com.aria.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Aria",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/index.js":                    "sidecar/index.js",
      "../sidecar/package.json":                "sidecar/package.json",
      "../sidecar/package-lock.json":           "sidecar/package-lock.json",
      "context/aria_personality.md":            "context/aria_personality.md",
      "context/user_profile.md":               "context/user_profile.md",
      "context/living_notes.md":               "context/living_notes.md",
      "context/tool_rules.md":                 "context/tool_rules.md",
      "context/skills.md":                     "context/skills.md",
      "../voice-sidecar/whisper_server.py":    "voice-sidecar/whisper_server.py",
      "../dashboard/index.html":               "dashboard/index.html",
      "../dashboard/subscriptions.html":       "dashboard/subscriptions.html",
      "../dashboard/finance.html":             "dashboard/finance.html",
      "../dashboard/income.html":              "dashboard/income.html",
      "../dashboard/budget.html":             "dashboard/budget.html",
      "../dashboard/timesheets.html":          "dashboard/timesheets.html",
      "../dashboard/vault.html":               "dashboard/vault.html",
      "../dashboard/shared/style.css":         "dashboard/shared/style.css",
      "../dashboard/js/brand-logos.js":        "dashboard/js/brand-logos.js",
      "../dashboard/js/income.js":             "dashboard/js/income.js",
      "pricing.json":                          "pricing.json",
      "../assets/aria_logo.png":               "assets/aria_logo.png"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
